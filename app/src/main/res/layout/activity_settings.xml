<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#0a0a0f"
    android:gravity="center"
    android:orientation="vertical"
    android:padding="48dp">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="⚙ Settings"
        android:textColor="#e8e8f0"
        android:textSize="32sp"
        android:textStyle="bold"
        android:layout_marginBottom="32dp" />

    <!-- Current URL label -->
    <TextView
        android:layout_width="600dp"
        android:layout_height="wrap_content"
        android:text="Dashboard URL"
        android:textColor="#6e6e82"
        android:textSize="14sp"
        android:textAllCaps="true"
        android:letterSpacing="0.1"
        android:layout_marginBottom="8dp" />

    <EditText
        android:id="@+id/urlInput"
        android:layout_width="600dp"
        android:layout_height="60dp"
        android:background="@drawable/input_background"
        android:textColor="#e8e8f0"
        android:textColorHint="#4a4a5a"
        android:textSize="18sp"
        android:hint="Enter URL"
        android:inputType="textUri"
        android:paddingStart="20dp"
        android:paddingEnd="20dp"
        android:singleLine="true"
        android:imeOptions="actionDone"
        android:focusable="true"
        android:focusableInTouchMode="true"
        android:layout_marginBottom="24dp" />

    <!-- Buttons -->
    <LinearLayout
        android:layout_width="600dp"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginBottom="16dp">

        <Button
            android:id="@+id/btnCancel"
            android:layout_width="0dp"
            android:layout_weight="1"
            android:layout_height="56dp"
            android:text="Cancel"
            android:textSize="17sp"
            android:textColor="#6e6e82"
            android:background="@drawable/btn_cancel"
            android:layout_marginEnd="8dp"
            android:focusable="true" />

        <Button
            android:id="@+id/btnSave"
            android:layout_width="0dp"
            android:layout_weight="1"
            android:layout_height="56dp"
            android:text="✓ Save"
            android:textSize="17sp"
            android:textColor="#ffffff"
            android:background="@drawable/btn_save"
            android:focusable="true" />
    </LinearLayout>

    <Button
        android:id="@+id/btnReset"
        android:layout_width="600dp"
        android:layout_height="48dp"
        android:text="Reset App (show setup on next launch)"
        android:textSize="14sp"
        android:textColor="#f87171"
        android:background="@drawable/btn_cancel"
        android:focusable="true"
        android:layout_marginTop="8dp" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Press BACK to return to dashboard"
        android:textColor="#4a4a5a"
        android:textSize="13sp"
        android:layout_marginTop="20dp" />

</LinearLayout>
